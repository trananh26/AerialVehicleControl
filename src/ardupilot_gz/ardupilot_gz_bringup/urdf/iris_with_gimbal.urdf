<?xml version="1.0"?>
<robot name="iris_with_gimbal">
  <!-- Base Link -->
  <link name="base_link">
    <inertial>
      <mass value="1.56"/>
      <inertia ixx="0.0347563" ixy="0" ixz="0" iyy="0.0458929" iyz="0" izz="0.0977"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.47 0.47 0.11"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 0.9"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.47 0.47 0.11"/>
      </geometry>
    </collision>
  </link>

  <!-- Standoff Links (for support) -->
  <link name="standoff_0">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.07"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 0.8"/>
      </material>
    </visual>
  </link>

  <link name="standoff_1">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.07"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 0.8"/>
      </material>
    </visual>
  </link>

  <link name="standoff_2">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.07"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 0.8"/>
      </material>
    </visual>
  </link>

  <link name="standoff_3">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.07"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Standoff Joints -->
  <joint name="standoff_0_joint" type="fixed">
    <origin xyz="0.13 -0.22 -0.035"/>
    <parent link="base_link"/>
    <child link="standoff_0"/>
  </joint>

  <joint name="standoff_1_joint" type="fixed">
    <origin xyz="-0.13 0.2 -0.035"/>
    <parent link="base_link"/>
    <child link="standoff_1"/>
  </joint>

  <joint name="standoff_2_joint" type="fixed">
    <origin xyz="-0.13 -0.22 -0.035"/>
    <parent link="base_link"/>
    <child link="standoff_2"/>
  </joint>

  <joint name="standoff_3_joint" type="fixed">
    <origin xyz="0.13 0.2 -0.035"/>
    <parent link="base_link"/>
    <child link="standoff_3"/>
  </joint>

  <!-- Rotor 0 (Front Right) -->
  <joint name="rotor_0_joint" type="continuous">
    <origin xyz="0.13 -0.22 0.023"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="rotor_0"/>
  </joint>
  <link name="rotor_0">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Rotor 1 (Back Left) -->
  <joint name="rotor_1_joint" type="continuous">
    <origin xyz="-0.13 0.2 0.023"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="rotor_1"/>
  </joint>
  <link name="rotor_1">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Rotor 2 (Front Left) -->
  <joint name="rotor_2_joint" type="continuous">
    <origin xyz="-0.13 -0.22 0.023"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="rotor_2"/>
  </joint>
  <link name="rotor_2">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Rotor 3 (Back Right) -->
  <joint name="rotor_3_joint" type="continuous">
    <origin xyz="0.13 0.2 0.023"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="rotor_3"/>
  </joint>
  <link name="rotor_3">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Gimbal Base Link -->
  <link name="gimbal_base">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 0.8"/>
      </material>
    </visual>
  </link>

  <joint name="gimbal_base_joint" type="fixed">
    <origin xyz="0 -0.01 -0.125"/>
    <parent link="base_link"/>
    <child link="gimbal_base"/>
  </joint>

  <!-- Gimbal Roll Link -->
  <link name="roll_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.15"/>
      </geometry>
      <material name="silver">
        <color rgba="0.8 0.8 0.8 0.9"/>
      </material>
    </visual>
  </link>

  <joint name="gimbal_roll_joint" type="revolute">
    <origin xyz="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
    <parent link="gimbal_base"/>
    <child link="roll_link"/>
  </joint>

  <!-- Gimbal Pitch Link -->
  <link name="pitch_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.15"/>
      </geometry>
      <material name="silver">
        <color rgba="0.8 0.8 0.8 0.9"/>
      </material>
    </visual>
  </link>

  <joint name="gimbal_pitch_joint" type="revolute">
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
    <parent link="roll_link"/>
    <child link="pitch_link"/>
  </joint>

  <!-- Camera Link (at end of gimbal) -->
  <link name="gimbal_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.06 0.06 0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 0.9"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.06 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="gimbal_yaw_joint" type="revolute">
    <origin xyz="0 0 -0.08"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="1"/>
    <parent link="pitch_link"/>
    <child link="gimbal_link"/>
  </joint>

  <!-- IMU Link -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <material name="orange">
        <color rgba="1 0.5 0 0.7"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>

</robot>
