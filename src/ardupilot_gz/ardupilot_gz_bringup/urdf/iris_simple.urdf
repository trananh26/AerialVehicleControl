<?xml version="1.0"?>
<robot name="iris">
  <!-- Base link -->
  <link name="base_link">
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.0347563" ixy="0" ixz="0" iyy="0.0458929" iyz="0" izz="0.0977"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.47 0.47 0.11"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 0.8"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.47 0.47 0.11"/>
      </geometry>
    </collision>
  </link>

  <!-- Rotor 0 (Front Right) -->
  <joint name="rotor_0_joint" type="continuous">
    <origin xyz="0.13 -0.22 0.023"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="rotor_0"/>
  </joint>
  <link name="rotor_0">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Rotor 1 (Back Left) -->
  <joint name="rotor_1_joint" type="continuous">
    <origin xyz="-0.13 0.2 0.023"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="rotor_1"/>
  </joint>
  <link name="rotor_1">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Rotor 2 (Front Left) -->
  <joint name="rotor_2_joint" type="continuous">
    <origin xyz="-0.13 -0.22 0.023"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="rotor_2"/>
  </joint>
  <link name="rotor_2">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Rotor 3 (Back Right) -->
  <joint name="rotor_3_joint" type="continuous">
    <origin xyz="0.13 0.2 0.023"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="rotor_3"/>
  </joint>
  <link name="rotor_3">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 0.8"/>
      </material>
    </visual>
  </link>

  <!-- Gimbal link (simple representation) -->
  <joint name="gimbal_joint" type="fixed">
    <origin xyz="0 0 -0.05"/>
    <parent link="base_link"/>
    <child link="gimbal_link"/>
  </joint>
  <link name="gimbal_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 0.6"/>
      </material>
    </visual>
  </link>

</robot>
